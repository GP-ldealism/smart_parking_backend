<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.gp.smartparking.mapper.ParkingOrderMapper">

    <resultMap id="BaseResultMap" type="cn.gp.smartparking.model.entity.ParkingOrder">
            <id property="id" column="id" />
            <result property="orderNo" column="order_no" />
            <result property="userId" column="user_id" />
            <result property="parkingLotId" column="parking_lot_id" />
            <result property="spaceNo" column="space_no" />
            <result property="plateNumber" column="plate_number" />
            <result property="type" column="type" />
            <result property="startTime" column="start_time" />
            <result property="endTime" column="end_time" />
            <result property="durationMinutes" column="duration_minutes" />
            <result property="amount" column="amount" />
            <result property="status" column="status" />
            <result property="version" column="version" />
            <result property="createBy" column="create_by" />
            <result property="createTime" column="create_time" />
            <result property="updateBy" column="update_by" />
            <result property="updateTime" column="update_time" />
            <result property="isDeleted" column="is_deleted" />
    </resultMap>

    <sql id="Base_Column_List">
        id,order_no,user_id,parking_lot_id,space_no,plate_number,
        type,start_time,end_time,duration_minutes,amount,
        status,version,create_by,create_time,update_by,
        update_time,is_deleted
    </sql>

    <select id="getUserOrderStatistics" resultType="cn.gp.smartparking.model.vo.OrderStatisticVO">
        select
            count(*) as totalCount,
            coalesce(sum(duration_minutes), 0) as totalDurationMinutes,
            coalesce(sum(amount), 0) as totalAmount
        from parking_order
        where
            user_id = #{id, jdbcType=INTEGER}
    </select>
</mapper>
